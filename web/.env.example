# Local development. Copy to web/.env and fill in.
DATABASE_URL="mysql://root:password@localhost:3306/speedison_dev"

# Transactional mail via Misshosting SMTP (sender = info@speedison.se).
SMTP_HOST="mail.misshosting.se"
SMTP_PORT="587"
SMTP_USER="info@speedison.se"
SMTP_PASS=""
# Optional: force TLS even on non-465 ports
# SMTP_SECURE="true"

# From / To headers used by lib/mailer.ts
MAIL_FROM='"Speedison" <info@speedison.se>'
MAIL_TO="info@speedison.se"

# Salt for IP-hashing used by rate-limit. Generate one with:
#   openssl rand -hex 32
IP_HASH_SALT="dev-only-salt-do-not-use-in-prod"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# For scripts/generate-luma-videos.mjs (one-time video generation).
# Get an API key at https://lumalabs.ai/dream-machine/api/keys.
LUMA_API_KEY=
